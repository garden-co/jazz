{
  "name": "wequencer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx tsx scripts/dev.ts",
    "build": "node ../../packages/jazz-tools/dist/cli.js validate && vite build",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.browser.ts",
    "test:e2e": "playwright test",
    "walkthrough": "npx @marp-team/marp-cli --html walkthrough/jazz-wequencer.md --preview",
    "walkthrough:shots": "playwright test --config playwright.screenshots.config.ts"
  },
  "dependencies": {
    "jazz-tools": "workspace:*",
    "svelte": "^5.0.0",
    "tone": "^15.1.22"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sveltejs/vite-plugin-svelte": "catalog:default",
    "@vitejs/plugin-basic-ssl": "^2.2.0",
    "@vitest/browser": "catalog:default",
    "@vitest/browser-playwright": "catalog:default",
    "tsx": "^4.0.0",
    "typescript": "catalog:default",
    "vite": "catalog:default",
    "vite-plugin-top-level-await": "catalog:default",
    "vite-plugin-wasm": "catalog:default",
    "vitest": "catalog:default"
  }
}
