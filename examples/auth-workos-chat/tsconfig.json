{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx"
  },
  "include": [
    ".env",
    "constants.ts",
    "src",
    "../auth-simple-chat/src/ChatPanel.tsx",
    "schema",
    "server",
    "scripts",
    "e2e",
    "playwright.config.ts"
  ],
  "exclude": ["schema/permissions.test.ts"]
}
