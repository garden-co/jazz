{
  "name": "world-tour",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node ../../packages/jazz-tools/dist/cli.js validate && vite build",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.browser.ts",
    "walkthrough": "npx @marp-team/marp-cli --html --theme walkthrough/theme-jazz.css walkthrough/jazz-world-tour.md --preview",
    "walkthrough:shots": "NODE_OPTIONS='--import ./walkthrough/patch-expect.mjs' playwright test --config playwright.screenshots.config.ts"
  },
  "dependencies": {
    "jazz-tools": "workspace:*",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-vue": "catalog:default",
    "@vitest/browser": "catalog:default",
    "@vitest/browser-playwright": "catalog:default",
    "typescript": "catalog:default",
    "vite": "catalog:default",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0",
    "vitest": "catalog:default"
  }
}
