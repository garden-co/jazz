{
  "name": "bluesky-offline-react",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names server,vite \"pnpm dev:server\" \"pnpm dev:vite\"",
    "dev:vite": "vite",
    "dev:server": "wait-on --timeout 20000 tcp:127.0.0.1:4200 && tsx --env-file=.env server/index.ts",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.server.json --noEmit",
    "build:server": "node --eval \"require('node:fs').rmSync('server-dist', { recursive: true, force: true })\" && tsc -p tsconfig.server.json",
    "build": "pnpm typecheck && vite build && pnpm build:server",
    "preview": "vite preview",
    "start": "node server-dist/server/index.js",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@atproto/common-web": "^0.5.6",
    "@atproto/oauth-client-node": "^0.4.4",
    "@hono/node-server": "^1.14.4",
    "@radix-ui/themes": "^3.3.0",
    "hono": "^4.7.11",
    "jose": "^6.2.1",
    "jazz-tools": "workspace:*",
    "react": "catalog:default",
    "react-dom": "catalog:default"
  },
  "devDependencies": {
    "@types/node": "catalog:default",
    "@rolldown/plugin-babel": "catalog:default",
    "@types/react": "catalog:default",
    "@types/react-dom": "catalog:default",
    "@vitejs/plugin-react": "catalog:default",
    "babel-plugin-react-compiler": "catalog:default",
    "concurrently": "catalog:default",
    "tsx": "catalog:default",
    "typescript": "catalog:default",
    "vite": "catalog:default",
    "vitest": "catalog:default",
    "wait-on": "catalog:default"
  }
}
