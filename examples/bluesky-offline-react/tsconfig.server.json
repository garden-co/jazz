{
  "compilerOptions": {
    "target": "ES2022",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "server-dist",
    "rootDir": ".",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"]
  },
  "include": ["server/**/*.ts", "schema.ts", "permissions.ts", "operations.ts", "object-id.ts", "at-uri.ts"],
  "exclude": ["server/**/*.test.ts"]
}
