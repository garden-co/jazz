{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsx": "preserve",
    "isolatedModules": true,
    "useDefineForClassFields": true
  },
  "include": ["src", "src/**/*.vue"]
}
