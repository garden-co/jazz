{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "typeRoots": ["./node_modules/@types"]
  },
  "include": ["App.tsx", "src/**/*", "schema/**/*"],
  "exclude": ["schema/**/*.test.ts"],
  "extends": "expo/tsconfig.base"
}
