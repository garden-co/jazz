{
  "name": "auth-betterauth-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:auth\" \"npm run dev:client\"",
    "dev:auth": "npm run db:migrate && tsx server/auth-server.ts",
    "dev:client": "vite",
    "build": "vite build",
    "db:migrate": "npx @better-auth/cli migrate --config server/auth-server.ts -y",
    "test": "playwright test",
    "test:ui": "playwright test --ui"
  },
  "dependencies": {
    "@jazz/client": "workspace:*",
    "@jazz/react": "workspace:*",
    "better-auth": "^1.2.0",
    "better-sqlite3": "^11.8.1",
    "express": "^4.21.2",
    "cors": "^2.8.5",
    "groove-wasm": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^9.1.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^5.0.0",
    "vite-plugin-top-level-await": "^1.4.0",
    "vite-plugin-wasm": "^3.3.0"
  }
}
