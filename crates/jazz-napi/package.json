{
  "name": "jazz-napi",
  "version": "0.1.0",
  "description": "Native Node.js bindings for Jazz runtime",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/garden-co/jazz2"
  },
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "build:debug": "napi build --platform"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2"
  },
  "napi": {
    "name": "jazz-napi",
    "triples": {
      "defaults": false,
      "additional": [
        "x86_64-unknown-linux-gnu",
        "x86_64-pc-windows-msvc",
        "x86_64-apple-darwin",
        "aarch64-apple-darwin"
      ]
    }
  }
}
