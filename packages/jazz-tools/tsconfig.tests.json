{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": false,
    "declarationMap": false,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noUncheckedIndexedAccess": true,
    "rootDir": ".",
    "sourceMap": false,
    "paths": {
      "jazz-tools": ["./src/index.ts"],
      "jazz-tools/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "tests/ts-dsl/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
