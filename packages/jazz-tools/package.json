{
  "name": "jazz-tools",
  "version": "2.0.0-alpha.21",
  "description": "Jazz TypeScript SDK, React/Vue/Svelte bindings, and CLI tools",
  "bin": {
    "jazz-tools": "bin/jazz-tools.js"
  },
  "files": [
    "bin/**",
    "dist/**",
    "README.md"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./backend": {
      "types": "./dist/backend/index.d.ts",
      "default": "./dist/backend/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "default": "./dist/react/index.js"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "default": "./dist/vue/index.js"
    },
    "./react-core": {
      "types": "./dist/react-core/index.d.ts",
      "react-native": "./dist/react-native/react-core.js",
      "default": "./dist/react-core/index.js"
    },
    "./permissions": {
      "types": "./dist/permissions/index.d.ts",
      "default": "./dist/permissions/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "default": "./dist/testing/index.js"
    },
    "./react-native": {
      "types": "./dist/react-native/index.d.ts",
      "react-native": "./dist/react-native/index.js",
      "default": "./dist/react-native/index.js"
    },
    "./svelte": {
      "types": "./dist/svelte/index.d.ts",
      "svelte": "./dist/svelte/index.js",
      "default": "./dist/svelte/index.js"
    },
    "./expo/polyfills": {
      "types": "./dist/expo/polyfills.d.ts",
      "react-native": "./dist/expo/polyfills.js",
      "default": "./dist/expo/polyfills.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "scripts": {
    "build": "tsc && cp src/worker/jazz-worker.ts dist/worker/jazz-worker.ts && pnpm build:test && pnpm build:svelte",
    "build:svelte": "svelte-package -i src/svelte -o dist/svelte --tsconfig tsconfig.svelte.json && node scripts/cleanup-generated-src-types.mjs",
    "test": "vitest run --config vitest.config.ts",
    "build:test": "node dist/cli.js build --schema-dir tests/ts-dsl/fixtures/basic && tsc --project tsconfig.tests.json",
    "test:browser": "vitest run --config vitest.config.browser.ts",
    "bench:realistic:browser": "vitest run --config vitest.config.browser.ts tests/browser/realistic-bench.test.ts",
    "stage:local": "node scripts/stage-local-binary.mjs",
    "pack:dry-run": "npm pack --dry-run"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0",
    "jazz-rn": "workspace:*",
    "jazz-wasm": "workspace:*",
    "json-schema-to-ts": "^3.1.1",
    "pluralize-esm": "^9.0.5",
    "tsx": "^4.0.0",
    "web-streams-polyfill": "^4.2.0"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/browser": "catalog:default",
    "@vitest/browser-playwright": "catalog:default",
    "fake-indexeddb": "^5.0.2",
    "react-dom": "^19.0.0",
    "svelte": "^5.0.0",
    "typescript": "catalog:default",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0",
    "vitest": "catalog:default",
    "vue": "^3.5.22",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "expo": ">=54",
    "react": "^18 || ^19",
    "react-native": ">=0.76",
    "svelte": "^5.0.0",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "expo": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "jazz-napi": "workspace:*"
  },
  "engines": {
    "node": ">=20"
  }
}
