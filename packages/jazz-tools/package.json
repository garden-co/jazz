{
  "name": "jazz-tools",
  "version": "2.0.0-alpha.0",
  "description": "Jazz TypeScript SDK, React bindings, and CLI tools",
  "bin": {
    "jazz-tools": "bin/jazz-tools.js"
  },
  "files": [
    "bin/**",
    "dist/**",
    "README.md"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./backend": {
      "types": "./dist/backend/index.d.ts",
      "default": "./dist/backend/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "default": "./dist/react/index.js"
    },
    "./permissions": {
      "types": "./dist/permissions/index.d.ts",
      "default": "./dist/permissions/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "default": "./dist/testing/index.js"
    },
    "./react-native": {
      "types": "./dist/react-native/index.d.ts",
      "react-native": "./dist/react-native/index.js",
      "default": "./dist/react-native/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "scripts": {
    "build": "tsc && cp src/worker/groove-worker.ts dist/worker/groove-worker.ts",
    "test": "vitest run --config vitest.config.ts",
    "test:build": "node dist/cli.js build --schema-dir tests/ts-dsl/fixtures/basic",
    "test:browser": "vitest run --config vitest.config.browser.ts",
    "stage:local": "node scripts/stage-local-binary.mjs",
    "pack:dry-run": "npm pack --dry-run"
  },
  "dependencies": {
    "tsx": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@vitest/browser": "catalog:default",
    "@vitest/browser-playwright": "catalog:default",
    "fake-indexeddb": "^5.0.2",
    "jazz-rn": "workspace:*",
    "jazz-wasm": "workspace:*",
    "typescript": "^5.3.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0",
    "vitest": "catalog:default"
  },
  "peerDependencies": {
    "react": "^18 || ^19"
  },
  "engines": {
    "node": ">=20"
  }
}
