{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "jsx": "preserve",
    "jsxImportSource": "solid-js"
  },
  "include": ["src/solid/**/*", "src/types/**/*.d.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.svelte.test.ts",
    "src/svelte/test-helpers.svelte.ts"
  ]
}
