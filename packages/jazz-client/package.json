{
  "name": "@jazz/client",
  "version": "0.0.1",
  "description": "Core runtime client for Jazz databases",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "generate:test": "tsx test/generate.ts",
    "test": "pnpm generate:test && vitest run",
    "test:watch": "pnpm generate:test && vitest"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@vitest/browser": "^2.1.9",
    "groove-wasm": "workspace:*",
    "playwright": "^1.57.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^5.0.0",
    "vite-plugin-top-level-await": "^1.4.0",
    "vite-plugin-wasm": "^3.3.0",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@jazz/schema": "workspace:*"
  }
}
