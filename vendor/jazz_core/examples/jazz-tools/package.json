{
  "name": "jazz-tools",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/jazz-tools/src/index.d.ts",
      "default": "./dist/jazz-tools/src/index.js"
    },
    "./react": {
      "types": "./dist/jazz-tools/src/react.d.ts",
      "default": "./dist/jazz-tools/src/react.js"
    },
    "./backend": {
      "types": "./dist/jazz-tools/src/backend.d.ts",
      "default": "./dist/jazz-tools/src/backend.js"
    },
    "./auth": {
      "types": "./dist/jazz-tools/src/auth.d.ts",
      "default": "./dist/jazz-tools/src/auth.js"
    }
  },
  "scripts": {
    "build:wasm": "cd ../../jazz-wasm && wasm-pack build --target nodejs",
    "check": "tsc --noEmit",
    "build": "tsc",
    "link:wasm": "mkdir -p jazz-wasm dist/jazz-wasm && ln -sfn ../../../jazz-wasm/pkg jazz-wasm/pkg && ln -sfn ../../../../jazz-wasm/pkg dist/jazz-wasm/pkg",
    "start:alpha-public-flow": "npm run link:wasm && node dist/jazz-tools/src/alpha-public-flow-gate.js",
    "test:alpha-public-flow": "npm run build && npm run start:alpha-public-flow",
    "test:auth-session": "npm run build && node --test dist/jazz-tools/src/auth-session.test.js",
    "test:auth-secret-store": "npm run build && node --test dist/jazz-tools/src/auth-secret-store.test.js",
    "test:jazz-client": "npm run build && node --test dist/jazz-tools/src/jazz-client.test.js",
    "test:react-provider": "npm run build && node --test dist/jazz-tools/src/react-provider-compat.test.js",
    "test:package-root-public-api": "npm run build && node --test dist/jazz-tools/src/package-root-public-api.test.js",
    "test:file-blob": "npm run build && node --test dist/jazz-tools/src/file-blob.test.js",
    "test:schema-dsl": "npm run build && node --test dist/jazz-tools/src/schema-dsl-compat.test.js",
    "test:transaction-compat": "npm run build && node --test dist/jazz-tools/src/transaction-compat.test.js",
    "test:backend": "npm run build && node --test dist/jazz-tools/src/backend.test.js",
    "test": "npm run test:auth-session && npm run test:auth-secret-store && npm run test:jazz-client && npm run test:react-provider && npm run test:package-root-public-api && npm run test:schema-dsl && npm run test:transaction-compat && npm run test:backend && npm run test:file-blob"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "@types/react": "^19.2.17",
    "@types/react-test-renderer": "^19.1.0",
    "react": "^19.2.7",
    "react-test-renderer": "^19.2.7",
    "typescript": "^5.8.3"
  }
}
