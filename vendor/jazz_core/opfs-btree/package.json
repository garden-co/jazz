{
  "name": "@jazz/opfs-btree",
  "private": true,
  "scripts": {
    "bench:wasm:build": "RUSTFLAGS='--cfg=web_sys_unstable_apis' wasm-pack build --target web --out-dir wasm-bench/pkg --release",
    "bench:wasm:opfs": "node wasm-bench/run-opfs-bench.cjs",
    "bench:wasm:opfs:mixed": "node wasm-bench/run-opfs-bench.cjs --profile mixed",
    "bench:wasm:opfs:range": "node wasm-bench/run-opfs-bench.cjs --profile range",
    "bench:wasm": "pnpm run bench:wasm:build && pnpm run bench:wasm:opfs"
  },
  "devDependencies": {
    "playwright": "^1.58.2",
    "wasm-pack": "^0.14.0"
  }
}
