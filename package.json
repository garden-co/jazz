{
  "scripts": {
    "format": "oxfmt .",
    "format:check": "oxfmt --check . && cargo fmt --check",
    "lint": "oxlint . && cargo clippy --workspace -- -D warnings",
    "build": "turbo run build:crates && turbo run build",
    "test": "turbo run test",
    "postinstall": "lefthook install"
  },
  "devDependencies": {
    "lefthook": "^2.0.15",
    "oxfmt": "^0.27.0",
    "oxlint": "^1.42.0",
    "turbo": "^2.0.0"
  },
  "packageManager": "pnpm@10.14.0"
}
