{
  "scripts": {
    "format": "oxfmt .",
    "format:check": "oxfmt --check . && cargo fmt --check",
    "lint": "oxlint . && cargo clippy --workspace -- -D warnings",
    "build": "turbo run build:crates --filter=@jazz/rust && turbo run build",
    "test": "turbo run test",
    "bench:realistic:update-history": "node benchmarks/realistic/update_history.mjs",
    "bench:realistic:build-site": "node benchmarks/realistic/build_site.mjs",
    "bench:realistic:render": "node benchmarks/realistic/render_deltas.mjs",
    "postinstall": "lefthook install"
  },
  "devDependencies": {
    "lefthook": "^2.0.15",
    "oxfmt": "^0.27.0",
    "oxlint": "^1.42.0",
    "playwright": "^1.58.2",
    "turbo": "^2.0.0"
  },
  "packageManager": "pnpm@10.14.0"
}
