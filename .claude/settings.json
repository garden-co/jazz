{
  "permissions": {
    "allow": [
      "Bash(cargo build:*)",
      "Bash(cargo check:*)",
      "Bash(cargo clean:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo fmt:*)",
      "Bash(cargo run:*)",
      "Bash(cargo test:*)",
      "Bash(curl:*)",
      "Bash(DEBUG_FILTER=1 cargo test:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(for:*)",
      "Bash(grep:*)",
      "Bash(jq:*)",
      "Bash(RUST_BACKTRACE=1 cargo test:*)",
      "Bash(wasm-pack build:*)",
      "Bash(wc:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git merge:*)",
      "Bash(git merge-base:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git stash:*)",
      "Bash(git status:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(npm test:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm test:e2e:*)",
      "Bash(pnpm turbo run build:*)",
      "Bash(pnpm turbo run typecheck:*)",
      "Bash(pnpm --filter demo-app test:*)",
      "Bash(timeout 30 pnpm test:*)",
      "Bash(act:*)",
      "Bash(brew install:*)",
      "Bash(docker info:*)",
      "Bash(docker context inspect:*)",
      "Bash(open:*)",
      "Bash(pkill:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm install",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
