{
  "name": "opfs-btree-viewer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:wasm": "wasm-pack build --target web --dev --out-dir pkg",
    "build:wasm:release": "wasm-pack build --target web --release --out-dir pkg",
    "dev": "pnpm run build:wasm && vite --port 5488",
    "build": "pnpm run build:wasm:release && vite build",
    "test": "cargo test --manifest-path Cargo.toml"
  },
  "devDependencies": {
    "vite": "catalog:default"
  }
}
