        {
          "expr": "sum(rate(jazz_sync_messages_received_total{app_id=~\"$app_id\", env=~\"$env\"}[$__rate_interval]))",
          "legendFormat": ""
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
