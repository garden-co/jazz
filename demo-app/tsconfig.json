{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@jazz/schema": ["../packages/jazz-schema/dist/index.d.ts"],
      "@jazz/schema/runtime": ["../packages/jazz-schema/dist/runtime.d.ts"]
    }
  },
  "include": ["src"]
}
