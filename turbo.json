{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["package.json"],
      "outputs": ["dist/**", "target/**", "pkg/**"]
    },
    "typecheck": {
      "dependsOn": ["build"]
    },
    "test": {
      "dependsOn": ["build"],
      "cache": false
    }
  }
}
