{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "target/**", "pkg/**"]
    },
    "build:crates": {
      "dependsOn": ["^build:crates"],
      "outputs": ["../target/**", "groove-wasm/pkg/**"]
    },
    "test": {
      "dependsOn": ["build"],
      "cache": false
    }
  }
}
