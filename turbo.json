{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "pkg/**"],
      "env": ["JAZZ_NAPI_RELEASE"]
    },
    "docs#build": {
      "dependsOn": [
        "todo-client-localfirst-react#build",
        "todo-client-localfirst-ts#build",
        "todo-server-ts#build"
      ],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "jazz-napi#build": {
      "dependsOn": ["@jazz/rust#build:crates"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/crates/**/*.rs",
        "$TURBO_ROOT$/Cargo.toml",
        "$TURBO_ROOT$/Cargo.lock"
      ],
      "outputs": ["jazz-napi.node", "index.js", "index.d.ts"]
    },
    "jazz-wasm#build": {
      "dependsOn": ["@jazz/rust#build:crates"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/crates/**/*.rs",
        "$TURBO_ROOT$/Cargo.toml",
        "$TURBO_ROOT$/Cargo.lock"
      ],
      "outputs": ["pkg/**"]
    },
    "build:crates": {
      "dependsOn": ["^build:crates"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/crates/**/*.rs",
        "$TURBO_ROOT$/Cargo.toml",
        "$TURBO_ROOT$/Cargo.lock"
      ],
      "outputs": [
        "$TURBO_ROOT$/target/debug/jazz-tools",
        "$TURBO_ROOT$/target/debug/jazz-cloud-server"
      ]
    },
    "build:rn": {
      "dependsOn": ["^build:rn"],
      "inputs": [
        "rust/**",
        "$TURBO_ROOT$/crates/**/*.rs",
        "$TURBO_ROOT$/Cargo.toml",
        "$TURBO_ROOT$/Cargo.lock"
      ],
      "outputs": ["android/**", "ios/**", "lib/**", "src/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false
    }
  }
}
