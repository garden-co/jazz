{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["Cargo.lock", "**/Cargo.toml"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "target/**", "pkg/**"],
      "env": ["JAZZ_NAPI_RELEASE"]
    },
    "docs#build": {
      "dependsOn": [
        "todo-client-localfirst-react#build",
        "todo-client-localfirst-ts#build",
        "todo-server-ts#build"
      ],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "jazz-napi#build": {
      "outputs": ["jazz-napi.node", "index.d.ts"]
    },
    "jazz-wasm#build": {
      "dependsOn": ["@jazz/rust#build:crates"],
      "outputs": ["pkg/**"]
    },
    "build:crates": {
      "dependsOn": ["^build:crates"],
      "outputs": ["../target/debug/jazz*"]
    },
    "build:rn": {
      "dependsOn": ["^build:rn"],
      "inputs": ["rust/**"],
      "outputs": ["android/**", "ios/**", "lib/**", "src/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false
    }
  }
}
