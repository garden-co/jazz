{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        ".next/**",
        ".source/**",
        "*.wasm",
        "*.js",
        "*.d.ts"
      ],
      "cache": true
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "generate": {
      "dependsOn": ["^build"],
      "outputs": ["src/generated/**"],
      "cache": true
    },
    "generate:test": {
      "dependsOn": ["^build"],
      "outputs": ["test/generated/**"],
      "cache": true
    },
    "lint": {
      "cache": true
    }
  }
}
