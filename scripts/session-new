#!/bin/bash
set -e

# Configuration
REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SESSIONS_DIR="$(cd "$REPO_ROOT/.." && pwd)/jazz2-sessions"
ZED_CLI="/Applications/Zed.app/Contents/MacOS/cli"

# Require session name as argument
if [ -z "$1" ]; then
    echo "Usage: session-new <name>"
    echo "Example: session-new blob-impl"
    exit 1
fi

SESSION_NAME="$1"
WORKTREE_PATH="${SESSIONS_DIR}/${SESSION_NAME}"

# Check if session already exists
if [ -d "$WORKTREE_PATH" ]; then
    echo "Error: Session '$SESSION_NAME' already exists at $WORKTREE_PATH"
    exit 1
fi

# Ensure sessions directory exists
mkdir -p "$SESSIONS_DIR"

# Create the worktree with a new branch based on main
cd "$REPO_ROOT"
git worktree add -b "$SESSION_NAME" "$WORKTREE_PATH" main

echo "Created worktree at: $WORKTREE_PATH"

# Install dependencies
cd "$WORKTREE_PATH"
if [ -f "pnpm-lock.yaml" ]; then
    echo "Installing dependencies with pnpm..."
    pnpm install
elif [ -f "package-lock.json" ]; then
    echo "Installing dependencies with npm..."
    npm install
fi

# Open Zed in the worktree
if [ -x "$ZED_CLI" ]; then
    echo "Opening Zed..."
    "$ZED_CLI" "$WORKTREE_PATH"
else
    echo "Zed CLI not found at $ZED_CLI"
    echo "Please open manually: $WORKTREE_PATH"
fi

echo ""
echo "Session created: $SESSION_NAME"
echo "Path: $WORKTREE_PATH"
