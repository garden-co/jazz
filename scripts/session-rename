#!/bin/bash
set -e

# Configuration
REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SESSIONS_DIR="$(cd "$REPO_ROOT/.." && pwd)/jazz2-sessions"

# Check arguments
if [ -z "$1" ] || [ -z "$2" ]; then
    echo "Usage: session-rename <old-name> <new-name>"
    echo ""
    echo "Available sessions:"
    if [ -d "$SESSIONS_DIR" ]; then
        ls -1 "$SESSIONS_DIR" 2>/dev/null || echo "  (none)"
    else
        echo "  (none)"
    fi
    exit 1
fi

OLD_NAME="$1"
NEW_NAME="$2"
OLD_PATH="${SESSIONS_DIR}/${OLD_NAME}"
NEW_PATH="${SESSIONS_DIR}/${NEW_NAME}"

# Verify the old worktree exists
if [ ! -d "$OLD_PATH" ]; then
    echo "Error: Session '$OLD_NAME' not found at $OLD_PATH"
    exit 1
fi

# Verify the new name doesn't already exist
if [ -d "$NEW_PATH" ]; then
    echo "Error: Session '$NEW_NAME' already exists at $NEW_PATH"
    exit 1
fi

# Move the worktree using git worktree move
cd "$REPO_ROOT"
git worktree move "$OLD_PATH" "$NEW_PATH"

echo "Session renamed: $OLD_NAME -> $NEW_NAME"
echo "Path: $NEW_PATH"
