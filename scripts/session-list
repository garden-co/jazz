#!/bin/bash

# Configuration
REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SESSIONS_DIR="$(cd "$REPO_ROOT/.." && pwd)/jazz2-sessions"

echo "Active worktree sessions:"
echo ""

if [ ! -d "$SESSIONS_DIR" ]; then
    echo "  (none - sessions directory doesn't exist yet)"
    exit 0
fi

cd "$REPO_ROOT"

# Parse git worktree list output
FOUND=0
while IFS= read -r line; do
    # Extract path and branch from lines like:
    # /Users/anselm/jazz2-sessions/session-20260106-063430  123d4c8 [session-20260106-063430]
    WORKTREE_PATH=$(echo "$line" | awk '{print $1}')

    # Only show worktrees in our sessions directory
    if [[ "$WORKTREE_PATH" == "$SESSIONS_DIR"* ]]; then
        SESSION_NAME=$(basename "$WORKTREE_PATH")
        BRANCH=$(echo "$line" | grep -o '\[.*\]' | tr -d '[]')

        # Check for uncommitted changes
        DIRTY=""
        if [ -d "$WORKTREE_PATH" ]; then
            cd "$WORKTREE_PATH"
            if ! git diff --quiet 2>/dev/null || ! git diff --cached --quiet 2>/dev/null; then
                DIRTY=" (uncommitted changes)"
            fi
            cd "$REPO_ROOT"
        fi

        printf "  %-40s [%s]%s\n" "$SESSION_NAME" "$BRANCH" "$DIRTY"
        FOUND=1
    fi
done < <(git worktree list)

if [ "$FOUND" -eq 0 ]; then
    echo "  (none)"
fi
